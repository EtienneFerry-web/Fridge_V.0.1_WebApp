{% extends 'base.html.twig' %}
{% block title %}{{ recette.recetteLibelle }} - Fridge{% endblock %}
{% block body %}
    {% include '_partials/header.html.twig' %}
    <main class="container py-4">

        <nav aria-label="Fil d'ariane">
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="{{ path('app_home') }}">Accueil</a></li>
                <li class="breadcrumb-item"><a href="{{ path('app_recette_index') }}">Recettes</a></li>
                <li class="breadcrumb-item active">{{ recette.recetteLibelle }}</li>
            </ol>
        </nav>

        {% for message in app.flashes('success') %}
            <div class="alert alert-success">{{ message }}</div>
        {% endfor %}

        {% if recette.recettePhoto is defined and recette.recettePhoto %}
            <img src="{{ asset('uploads/recettes/' ~ recette.recettePhoto) }}"
                class="w-100 rounded shadow-sm mb-4" alt="{{ recette.recetteLibelle }}"
                style="height: 350px; object-fit: cover;">
        {% else %}
            <img src="https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=1200"
                class="w-100 rounded shadow-sm mb-4" alt="{{ recette.recetteLibelle }}"
                style="height: 350px; object-fit: cover;">
        {% endif %}

        <div class="bg-white rounded shadow-sm p-4">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <h1 class="h2 fw-bold">{{ recette.recetteLibelle }}</h1>
                {% if is_granted('ROLE_USER') %}
                    <div class="d-flex gap-2">
                        <a href="{{ path('app_recette_edit', {id: recette.id}) }}" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-pencil me-1"></i>Modifier
                        </a>
                        <form action="{{ path('app_recette_delete', {id: recette.id}) }}" method="POST"
                              onsubmit="return confirm('Supprimer cette recette ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_recette_' ~ recette.id) }}">
                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                <i class="bi bi-trash me-1"></i>Supprimer
                            </button>
                        </form>
                    </div>
                {% endif %}
            </div>

            <div class="d-flex flex-wrap gap-2 mb-4">
                <span class="badge bg-light text-dark border">
                    <i class="bi bi-clock me-1"></i>Prépa : {{ recette.recetteTempsPrepa }} min
                </span>
                <span class="badge bg-light text-dark border">
                    <i class="bi bi-fire me-1"></i>Cuisson : {{ recette.recetteTempsCuisson }} min
                </span>
                <span class="badge bg-light text-dark border">
                    <i class="bi bi-people me-1"></i>{{ recette.recettePortion }} portions
                </span>
                <span class="badge bg-light text-dark border">
                    <i class="bi bi-bar-chart me-1"></i>{{ recette.recetteDifficulte }}
                </span>
            </div>

            {% if recette.recetteDescription %}
                <p class="text-muted mb-4">{{ recette.recetteDescription }}</p>
            {% endif %}

            {% if recette.contenirs|length > 0 %}
                <h2 class="h5 fw-bold mb-3">Ingrédients</h2>
                <ul class="list-group mb-4">
                    {% for contenir in recette.contenirs %}
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <i class="bi bi-check2-circle text-primary me-2"></i>
                                {{ contenir.ingredient.ingredientLibelle }}
                            </div>
                            <span class="badge rounded-pill shadow-sm" style="background-color: var(--tomato-jam); color: var(--linen); border: 1.5px solid var(--tomato-dark);">
                                {{ contenir.contenirQuantite }} {{ contenir.contenirUnite }}
                            </span>
                        </li>
                    {% endfor %}
                </ul>
            {% endif %}

            {% if recette.etapes|length > 0 %}
                <h2 class="h5 fw-bold mb-3">Étapes</h2>
                <ol class="list-group list-group-numbered mb-4">
                    {% for etape in recette.etapes %}
                        <li class="list-group-item">
                            <strong>{{ etape.etapeLibelle }}</strong>
                            {% if etape.etapeDuree %}
                                <span class="badge bg-light text-dark ms-2">{{ etape.etapeDuree }} min</span>
                            {% endif %}
                            <p class="mb-0 text-muted small mt-1">{{ etape.etapeDescription }}</p>
                        </li>
                    {% endfor %}
                </ol>
            {% endif %}
        </div>
    </main>
    {% include '_partials/footer.html.twig' %}
{% endblock %}