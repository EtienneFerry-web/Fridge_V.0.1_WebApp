{{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
    <div class="mb-3">{{ form_row(form.recetteLibelle, {attr: {class: 'form-control'}}) }}</div>
    <div class="mb-3">{{ form_row(form.recetteDescription, {attr: {class: 'form-control'}}) }}</div>
    <div class="row g-3 mb-3">
        <div class="col-md-4">{{ form_row(form.recetteDifficulte, {attr: {class: 'form-select'}}) }}</div>
        <div class="col-md-4">{{ form_row(form.recettePortion, {attr: {class: 'form-control'}}) }}</div>
    </div>
    <div class="row g-3 mb-4">
        <div class="col-md-4">{{ form_row(form.recetteTempsPrepa, {attr: {class: 'form-control'}}) }}</div>
        <div class="col-md-4">{{ form_row(form.recetteTempsCuisson, {attr: {class: 'form-control'}}) }}</div>
    </div>

    {# INGRÉDIENTS #}
    <div class="mb-4">
        <label class="form-label fw-bold">Ingrédients</label>

        <div id="contenirs-container">
            {% for contenir in form.contenirs %}
                <div class="contenir-row mb-2" data-confirmed="true">

                    {# Champ hidden Symfony — toujours présent #}
                    {{ form_widget(contenir.ingredient, {
                        attr: {
                            class: 'ingredient-id-hidden',
                            'data-ingredient-hidden': '1'
                        }
                    }) }}
                    {{ form_widget(contenir.contenirQuantite, {
                        attr: {class: 'contenir-quantite-hidden d-none'}
                    }) }}
                    {{ form_widget(contenir.contenirUnite, {
                        attr: {class: 'contenir-unite-hidden d-none'}
                    }) }}

                    {# Ligne visuelle (mode confirmé) #}
                    <div class="contenir-display d-flex align-items-center gap-2 p-2 rounded"
                        style="background-color: #d4876e; color: white;">
                        <span class="flex-grow-1 fw-medium contenir-label">
                            {{ contenir.vars.data.ingredient ? contenir.vars.data.ingredient.ingredientLibelle : '' }}
                            <span class="opacity-75 fw-normal ms-1">
                                · {{ contenir.vars.data.contenirQuantite }}
                                {{ contenir.vars.data.contenirUnite }}
                            </span>
                        </span>
                        <button type="button" class="btn btn-sm btn-modifier-contenir"
                                style="color:white; border-color: rgba(255,255,255,0.5);">
                            <i class="bi bi-pencil"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-supprimer-contenir"
                                style="color:white; border-color: rgba(255,255,255,0.5);">
                            <i class="bi bi-trash"></i>
                        </button>
                    </div>

                    {# Ligne formulaire (mode édition — cachée par défaut) #}
                    <div class="contenir-form d-none d-flex gap-2 align-items-center p-2 rounded"
                        style="background-color: #d4876e;">
                        <div class="flex-grow-1" style="min-width: 160px;">
                            <input type="text" class="form-control ingredient-ts-input"
                                placeholder="Rechercher un ingrédient…">
                        </div>
                        <input type="number" class="form-control input-quantite"
                            placeholder="Qté" style="width:80px; flex-shrink:0;">
                        <select class="form-select input-unite" style="width:120px; flex-shrink:0;">
                            <option value="">Unité</option>
                            <option value="g">g</option>
                            <option value="kg">kg</option>
                            <option value="ml">ml</option>
                            <option value="l">l</option>
                            <option value="tsp">tsp</option>
                            <option value="tbsp">tbsp</option>
                            <option value="pièce(s)">pièce(s)</option>
                            <option value="gousse(s)">gousse(s)</option>
                            <option value="bouquet">bouquet</option>
                            <option value="pincée">pincée</option>
                            <option value="tranche(s)">tranche(s)</option>
                        </select>
                        <button type="button" class="btn btn-sm btn-confirmer-contenir flex-shrink-0"
                                style="color:white; border-color: rgba(255,255,255,0.5);" title="Confirmer">
                            <i class="bi bi-check-lg"></i>
                        </button>
                        <button type="button" class="btn btn-sm btn-annuler-contenir flex-shrink-0"
                                style="color:white; border-color: rgba(255,255,255,0.5);" title="Annuler">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>

                </div>
            {% endfor %}
        </div>

        <button type="button" id="btn-ajouter-contenir" class="btn btn-outline-primary btn-sm mt-2">
            <i class="bi bi-plus-lg me-1"></i> Ajouter un ingrédient
        </button>
    </div>

    <div id="contenirs-prototype"
        data-prototype="{{ form_widget(form.contenirs.vars.prototype)|e('html_attr') }}"
        style="display:none"></div>  
    {# ÉTAPES #}
    <div class="mb-4">
        <label class="form-label fw-bold">Étapes</label>
        <div id="etapes-container">
            {% for etape in form.etapes %}
                <div class="etape-row card mb-2 border-0 shadow-sm">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center mb-2">
                            <span class="badge bg-dark me-2 etape-numero">Étape ?</span>
                            <button type="button" class="btn btn-sm btn-outline-danger ms-auto btn-supprimer-etape">
                                <i class="bi bi-trash"></i>
                            </button>
                        </div>
                        {{ form_row(etape.etapeLibelle, {'attr': {'class': 'form-control'}}) }}
                        {{ form_row(etape.etapeDescription, {'attr': {'class': 'form-control'}}) }}
                        {{ form_row(etape.etapeDuree, {'attr': {'class': 'form-control'}}) }}
                    </div>
                </div>
            {% endfor %}
        </div>
        <button type="button" id="btn-ajouter-etape" class="btn btn-outline-primary btn-sm mt-2">
            <i class="bi bi-plus-lg me-1"></i> Ajouter une étape
        </button>
    </div>

    <div id="etapes-prototype"
         data-prototype="{{ form_widget(form.etapes.vars.prototype)|e('html_attr') }}"
         style="display:none"></div>

    {{ form_rest(form) }}

    <div class="d-flex gap-2">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-save me-1"></i>Enregistrer
        </button>
        <a href="{{ path('app_recette_index') }}" class="btn btn-outline-secondary">Annuler</a>
    </div>
{{ form_end(form) }}