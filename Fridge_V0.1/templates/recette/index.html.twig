{% extends 'base.html.twig' %}

{% block title %}Recettes - Fridge{% endblock %}

{% block body %}
    <main class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="h3 fw-bold mb-0">Toutes les recettes</h1>
            {% if is_granted('ROLE_USER') %}
                <a href="{{ path('app_recette_new') }}" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-1"></i> Nouvelle recette
                </a>
            {% endif %}
        </div>

        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for recette in recettes %}
                <div class="col">
                    <div class="card h-100">
                        <div class="card-body">
                            <h5 class="card-title">{{ recette.recetteLibelle }}</h5>
                            <p class="card-text text-muted small">{{ recette.recetteDescription|slice(0, 100) }}...</p>
                            <div class="d-flex gap-2 flex-wrap">
                                <span class="badge bg-light text-dark">
                                    <i class="bi bi-clock me-1"></i>{{ recette.recetteTempsPrepa + recette.recetteTempsCuisson }} min
                                </span>
                                <span class="badge bg-light text-dark">
                                    <i class="bi bi-bar-chart me-1"></i>{{ recette.recetteDifficulte }}
                                </span>
                                <span class="badge bg-light text-dark">
                                    <i class="bi bi-people me-1"></i>{{ recette.recettePortion }} pers.
                                </span>
                            </div>
                        </div>
                        <div class="card-footer d-flex justify-content-between">
                            <a href="{{ path('app_recette_show', {id: recette.id}) }}" class="btn btn-sm btn-outline-dark">
                                Voir la recette
                            </a>
                            {% if is_granted('ROLE_USER') %}
                                <a href="{{ path('app_recette_edit', {id: recette.id}) }}" class="btn btn-sm btn-outline-secondary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            {% else %}
                <p class="text-muted">Aucune recette disponible pour le moment.</p>
            {% endfor %}
        </div>
    </main>
{% endblock %}
