{% extends 'base.html.twig' %}

{% block title %}Page introuvable{% endblock %}

{% block body %}
    <main class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">

                <img src="{{ asset('img/fridge_error403.png') }}" alt="Fridge Hero"
                    class="img-fluid" style="max-height: 350px;">



                <h1 class="mb-3">403 — Accès refusé</h1>
                <p class="mb-4">Vous n'avez pas les autorisations nécessaires pour accéder à cette page.</p>

                <div class="d-flex gap-3 justify-content-center flex-wrap">
                    <a href="{{ path('app_home') }}" class="btn btn-primary px-4">
                        Retour à l'accueil
                    </a>
                    <a href="javascript:history.back()" class="btn btn-outline-secondary px-4">
                        Page précédente
                    </a>
                </div>

            </div>
        </div>
    </main>

{% endblock %}