{# templates/base.html.twig #}
<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <title>{% block title %}Fridge{% endblock %}</title>

        {% block stylesheets %}
            {# Bootstrap CDN #}
            <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
            {# Ton CSS : Symfony le trouvera dans assets/styles/styles.css #}
            <link rel="stylesheet" href="{{ asset('styles/styles.css') }}">
        {% endblock %}

        {% block javascripts %}
            {# On charge tes points d'entrée définis dans importmap.php #}
            {{ importmap(['app', 'script_perso']) }}
        {% endblock %}
    </head>
    <body>
        {% block body %}{% endblock %}
    </body>
</html>