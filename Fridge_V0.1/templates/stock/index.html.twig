{% extends 'base.html.twig' %}

{% block title %}Mon Stock - Fridge{% endblock %}

{% block body %}
{% include '_partials/header.html.twig' %}

<nav class="breadcrumb-nav" aria-label="Fil d'ariane">
    <div class="container">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('app_home') }}"><i class="bi bi-house me-1"></i>Accueil</a>
            </li>
            <li class="breadcrumb-item active">Mon Stock</li>
        </ol>
    </div>
</nav>

<main class="container py-4 py-md-5">

    {% include '_partials/flash.html.twig' %}

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4 gap-3">
        <div>
            <h1 class="h2 fw-bold mb-1">
                <i class="bi bi-basket3 me-2 text-primary"></i>Mon Stock d'Ingrédients
            </h1>
            <p class="text-muted mb-0">Gérez vos ingrédients et ne soyez plus jamais pris au dépourvu.</p>
        </div>
        <div class="d-flex gap-2 flex-wrap align-items-center">
            <span class="badge rounded-pill bg-primary fs-6 px-3 py-2">
                <i class="bi bi-box-seam me-1"></i>{{ arrStock|length }} article(s)
            </span>
            {# Bouton vider tout #}
            {% if arrStock|length > 0 %}
                <button class="btn btn-outline-danger btn-sm" data-bs-toggle="modal" data-bs-target="#clearModal">
                    <i class="bi bi-trash me-1"></i>Vider le stock
                </button>
            {% endif %}
        </div>
    </div>

    <div class="row g-4">

        {# FORMULAIRE AJOUT #}
        <div class="col-12 col-lg-4">
            <div class="card shadow-sm border-0 position-sticky" style="top: 85px;">
                <div class="card-body p-4">
                    <h2 class="h5 fw-bold mb-4 d-flex align-items-center gap-2" id="formTitle">
                        <span class="d-inline-flex align-items-center justify-content-center rounded-circle bg-primary text-white"
                            style="width:32px; height:32px;">
                            <i class="bi bi-plus-lg"></i>
                        </span>
                        Ajouter un ingrédient
                    </h2>

                    <form method="POST" action="{{ path('app_stock_add') }}" class="needs-validation" novalidate>

                        <div class="mb-3">
                            <label for="ingredientName" class="form-label">
                                Nom <span class="required-mark">*</span>
                            </label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-tag"></i></span>
                                <input type="text" id="ingredientName" name="ingredientName"
                                       class="form-control" placeholder="ex : Farine, Tomates..."
                                       required minlength="2" autocomplete="off">
                            </div>
                        </div>

                        <div class="row g-2 mb-3">
                            <div class="col-7">
                                <label for="ingredientQty" class="form-label">Quantité <span class="required-mark">*</span></label>
                                <input type="number" id="ingredientQty" name="ingredientQty"
                                       class="form-control" placeholder="ex : 500" min="0" step="0.01" required>
                            </div>
                            <div class="col-5">
                                <label for="ingredientUnit" class="form-label">Unité</label>
                                <select id="ingredientUnit" name="ingredientUnit" class="form-select">
                                    <option value="unité">unité</option>
                                    <option value="g">g</option>
                                    <option value="kg">kg</option>
                                    <option value="mL">mL</option>
                                    <option value="L">L</option>
                                    <option value="cL">cL</option>
                                    <option value="tbsp">c. à soupe</option>
                                    <option value="tsp">c. à café</option>
                                </select>
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="ingredientThreshold" class="form-label">Seuil d'alerte</label>
                            <input type="number" id="ingredientThreshold" name="ingredientThreshold"
                                   class="form-control" placeholder="ex : 100" min="0" step="0.01" value="0">
                            <div class="form-text">0 = pas d'alerte</div>
                        </div>

                        <div class="mb-4">
                            <label for="ingredientExpiry" class="form-label">Date de péremption</label>
                            <div class="input-group">
                                <span class="input-group-text"><i class="bi bi-calendar-event"></i></span>
                                <input type="date" id="ingredientExpiry" name="ingredientExpiry" class="form-control">
                            </div>
                        </div>

                        <button type="submit" class="btn btn-primary w-100">
                            <i class="bi bi-plus-circle me-2"></i>Ajouter au stock
                        </button>
                    </form>
                </div>
            </div>
        </div>

        {# LISTE DU STOCK #}
        <div class="col-12 col-lg-8">
            {% if arrStock is empty %}
                <div class="text-center py-5">
                    <i class="bi bi-basket display-3 text-muted d-block mb-3"></i>
                    <h3 class="h5 text-muted">Votre stock est vide</h3>
                    <p class="text-muted small">Ajoutez votre premier ingrédient via le formulaire.</p>
                </div>
            {% else %}
                {% for objStocker in arrStock %}
                    {% set today = "now"|date("Y-m-d") %}
                    {% set expiry = objStocker.stockerDatePeremption ? objStocker.stockerDatePeremption|date("Y-m-d") : null %}
                    {% set diffDays = expiry ? ((expiry|date("U") - today|date("U")) / 86400)|round : null %}

                    {% if expiry and diffDays < 0 %}
                        {% set statusClass = 'stock-card-expired' %}
                        {% set badgeHtml = '<span class="badge bg-danger rounded-pill">périmé</span>' %}
                        {% set icon = 'bi-x-circle-fill text-danger' %}
                    {% elseif expiry and diffDays <= 7 %}
                        {% set statusClass = 'stock-card-warning' %}
                        {% set badgeHtml = '<span class="badge stock-badge-warning rounded-pill">bientôt périmé</span>' %}
                        {% set icon = 'bi-clock-history stock-icon-warning' %}
                    {% elseif objStocker.stockerSeuil and objStocker.stockerQuantiteDispo <= objStocker.stockerSeuil %}
                        {% set statusClass = 'stock-card-low' %}
                        {% set badgeHtml = '<span class="badge stock-badge-low rounded-pill">stock bas</span>' %}
                        {% set icon = 'bi-exclamation-triangle-fill stock-icon-low' %}
                    {% else %}
                        {% set statusClass = '' %}
                        {% set badgeHtml = '<span class="badge stock-badge-ok rounded-pill">OK</span>' %}
                        {% set icon = 'bi-check-circle-fill stock-icon-ok' %}
                    {% endif %}

                    <div class="card shadow-sm border-0 mb-3 stock-item-card {{ statusClass }}">
                        <div class="card-body p-3">
                            <div class="row align-items-center g-2">
                                <div class="col-auto d-none d-sm-block">
                                    <i class="bi {{ icon }} fs-4"></i>
                                </div>
                                <div class="col">
                                    <div class="d-flex flex-wrap align-items-center gap-2 mb-1">
                                        <span class="fw-bold">{{ objStocker.ingredient.ingredientLibelle }}</span>
                                        {{ badgeHtml|raw }}
                                    </div>
                                    <div class="d-flex flex-wrap gap-3 small text-muted">
                                        <span>
                                            <i class="bi bi-box-seam me-1"></i>
                                            <strong class="text-dark">{{ objStocker.stockerQuantiteDispo }} {{ objStocker.stockerUnite }}</strong>
                                            {% if objStocker.stockerSeuil %}
                                                <span class="text-muted">/ seuil : {{ objStocker.stockerSeuil }} {{ objStocker.stockerUnite }}</span>
                                            {% endif %}
                                        </span>
                                        <span>
                                            <i class="bi bi-calendar me-1"></i>
                                            {% if expiry %}
                                                <span class="{{ diffDays < 0 ? 'text-danger fw-bold' : (diffDays <= 7 ? 'stock-text-warning fw-bold' : '') }}">
                                                    {{ objStocker.stockerDatePeremption|date("d/m/Y") }}
                                                </span>
                                            {% else %}
                                                <span class="fst-italic">Aucune date</span>
                                            {% endif %}
                                        </span>
                                    </div>
                                </div>
                                <div class="col-auto d-flex gap-2">
                                    <button class="btn btn-outline-secondary btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#editModal{{ objStocker.id }}">
                                        <i class="bi bi-pencil"></i>
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm"
                                            data-bs-toggle="modal"
                                            data-bs-target="#deleteModal{{ objStocker.id }}">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Modal modifier #}
                    <div class="modal fade" id="editModal{{ objStocker.id }}" tabindex="-1">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header">
                                    <h5 class="modal-title">Modifier — {{ objStocker.ingredient.ingredientLibelle }}</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <form method="POST" action="{{ path('app_stock_edit', {id: objStocker.id}) }}">
                                    <div class="modal-body">
                                        <div class="row g-2 mb-3">
                                            <div class="col-7">
                                                <label class="form-label">Quantité</label>
                                                <input type="number" name="ingredientQty" class="form-control"
                                                       value="{{ objStocker.stockerQuantiteDispo }}" min="0" step="0.01" required>
                                            </div>
                                            <div class="col-5">
                                                <label class="form-label">Unité</label>
                                                <select name="ingredientUnit" class="form-select">
                                                    {% for opt in ['unité','g','kg','mL','L','cL','tbsp','tsp'] %}
                                                        <option value="{{ opt }}" {{ objStocker.stockerUnite == opt ? 'selected' : '' }}>{{ opt }}</option>
                                                    {% endfor %}
                                                </select>
                                            </div>
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Seuil d'alerte</label>
                                            <input type="number" name="ingredientThreshold" class="form-control"
                                                   value="{{ objStocker.stockerSeuil ?? 0 }}" min="0" step="0.01">
                                        </div>
                                        <div class="mb-3">
                                            <label class="form-label">Date de péremption</label>
                                            <input type="date" name="ingredientExpiry" class="form-control"
                                                   value="{{ objStocker.stockerDatePeremption ? objStocker.stockerDatePeremption|date('Y-m-d') : '' }}">
                                        </div>
                                    </div>
                                    <div class="modal-footer">
                                        <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                                        <button type="submit" class="btn btn-primary">Enregistrer</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>

                    {# Modal supprimer #}
                    <div class="modal fade" id="deleteModal{{ objStocker.id }}" tabindex="-1">
                        <div class="modal-dialog modal-dialog-centered">
                            <div class="modal-content">
                                <div class="modal-header bg-danger">
                                    <h5 class="modal-title text-white"><i class="bi bi-trash me-2"></i>Supprimer</h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    Supprimer <strong>{{ objStocker.ingredient.ingredientLibelle }}</strong> du stock ?
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                                    <form method="POST" action="{{ path('app_stock_delete', {id: objStocker.id}) }}">
                                        <button type="submit" class="btn btn-danger">Supprimer</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>

                {% endfor %}
            {% endif %}
        </div>
    </div>
</main>

{# Modal vider tout #}
<div class="modal fade" id="clearModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header bg-danger">
                <h5 class="modal-title text-white"><i class="bi bi-trash me-2"></i>Vider le stock</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                Voulez-vous vraiment supprimer <strong>tous</strong> les ingrédients de votre stock ? Cette action est irréversible.
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Annuler</button>
                <form method="POST" action="{{ path('app_stock_clear') }}">
                    <button type="submit" class="btn btn-danger">Tout supprimer</button>
                </form>
            </div>
        </div>
    </div>
</div>

{% include '_partials/footer.html.twig' %}
{% endblock %}