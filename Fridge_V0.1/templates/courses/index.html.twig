{% extends 'base.html.twig' %}

{% block title %}Mes Listes de Courses - Fridge{% endblock %}

{% block body %}

<nav class="breadcrumb-nav" aria-label="Fil d'ariane">
    <div class="container">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('app_home') }}"><i class="bi bi-house me-1"></i>Accueil</a>
            </li>
            <li class="breadcrumb-item active">Listes de Courses</li>
        </ol>
    </div>
</nav>

<main class="container py-4 py-md-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="h2 fw-bold mb-1">
                <i class="bi bi-cart3 me-2 text-primary"></i>Mes Listes de Courses
            </h1>
            <p class="text-muted mb-0">Retrouvez vos listes générées depuis le planning.</p>
        </div>
        <form action="{{ path('app_liste_course_generer') }}" method="POST">
            <button type="submit" class="btn btn-primary">
                <i class="bi bi-plus-circle me-1"></i>Générer une nouvelle liste
            </button>
        </form>
    </div>

    {% if listes is empty %}
        <div class="text-center py-5 bg-white rounded shadow-sm">
            <i class="bi bi-cart-x display-3 text-muted mb-3"></i>
            <h3 class="h5 text-muted">Vous n'avez pas encore de liste de courses.</h3>
            <p class="text-muted">Générez-en une en ajoutant des recettes à votre planning !</p>
            <a href="{{ path('app_planning') }}" class="btn btn-outline-primary mt-2">
                Aller au planning
            </a>
        </div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for liste in listes %}
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 recipe-card">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title mb-0">{{ liste.listeLibelle }}</h5>
                                <span class="badge {{ liste.listeStatut == 'active' ? 'bg-primary' : 'bg-secondary' }} rounded-pill">
                                    {{ liste.listeStatut|capitalize }}
                                </span>
                            </div>
                            <p class="text-muted small mb-3">
                                <i class="bi bi-calendar-event me-1"></i>
                                Créée le {{ liste.listeDateCreation|date('d/m/Y à H:i') }}
                            </p>
                            <div class="d-flex align-items-center mb-3">
                                <div class="progress flex-grow-1" style="height: 6px;">
                                    {% set total = liste.contenirs|length %}
                                    {% set coches = 0 %}
                                    {% for item in liste.contenirs %}
                                        {% if item.contenirEstCoche %}{% set coches = coches + 1 %}{% endif %}
                                    {% endfor %}
                                    {% set percent = total > 0 ? (coches / total * 100)|round : 0 %}
                                    <div class="progress-bar bg-primary" style="width: {{ percent }}%"></div>
                                </div>
                                <span class="ms-2 small text-muted">{{ percent }}%</span>
                            </div>
                            <p class="small text-muted">{{ total }} article(s)</p>
                        </div>
                        <div class="card-footer bg-white border-0 pt-0 pb-3 px-3">
                            <div class="d-grid gap-2">
                                <a href="{{ path('app_liste_course_show', {id: liste.id}) }}" class="btn btn-outline-primary btn-sm bg-white">
                                    <i class="bi bi-eye me-1"></i>Voir les détails
                                </a>
                                <form action="{{ path('app_liste_course_delete', {id: liste.id}) }}" method="POST"
                                      onsubmit="return confirm('Supprimer cette liste définitivement ?')">
                                    <button type="submit" class="btn btn-outline-danger btn-sm w-100 bg-white">
                                        <i class="bi bi-trash me-1"></i>Supprimer
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% endif %}
</main>

{% endblock %}
