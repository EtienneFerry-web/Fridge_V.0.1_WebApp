{% extends 'base.html.twig' %}

{% block title %}Accueil - Fridge{% endblock %}

{% block stylesheets %}
    {# Import Splide #}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css">
{% endblock %}

{% block body %}
    {# 1. HEADER #}
    {% include '_partials/header.html.twig' %}

    <main>
        {# 2. COMPONENT HERO #}
        {% include 'components/_hero.html.twig' %}

        {# 3. CARROUSEL (Recettes du moment) #}
        <section id="newRecipes" class="container py-5">
            <div class="text-center mb-5">
                <h2 class="fw-bold">Les Recettes du moment</h2>
                <p class="text-muted">Les pépites de la communauté</p>
            </div>

            <div class="splide" id="recipe-carousel">
                <div class="splide__track">
                    <ul class="splide__list">
                        {# Carrousel en dure a modifier avec une boucle #}
                        <li class="splide__slide px-2">
                            {% include 'components/_recipe_card.html.twig' with {
                                'title': 'Bowl de Saison',
                                'category': 'Végétarien',
                                'category_color': 'bg-success',
                                'image': 'https://images.unsplash.com/photo-1546069901-ba9599a7e63c?w=500',
                                'time': '15'
                            } %}
                        </li>
                        <li class="splide__slide px-2">
                            {% include 'components/_recipe_card.html.twig' with {
                                'title': 'Pesto Maison',
                                'category': 'Rapide',
                                'category_color': 'bg-danger',
                                'image': 'https://images.unsplash.com/photo-1473093226795-af9932fe5856?w=500',
                                'time': '10'
                            } %}
                        </li>
                        <li class="splide__slide px-2">
                            {% include 'components/_recipe_card.html.twig' with {
                                'title': 'Pancakes Moelleux',
                                'category': 'Petit-déj',
                                'category_color': 'bg-warning text-dark',
                                'image': 'https://images.unsplash.com/photo-1567620905732-2d1ec7bb7445?w=500',
                                'time': '20'
                            } %}
                        </li>
                    </ul>
                </div>
            </div>
        </section>

        {# 4. FIL DE RECETTES (Mise en avant) #}
        <section id="recipeFeed" class="container py-5 border-top">
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-center mb-4 gap-3">
                <h2 class="fw-bold m-0">Toutes les recettes</h2>
                <div class="dropdown">
                    <button class="btn btn-white border shadow-sm dropdown-toggle" type="button" data-bs-toggle="dropdown">
                        Trier par
                    </button>
                    <ul class="dropdown-menu shadow">
                        <li><a class="dropdown-item" href="#">Plus récentes</a></li>
                        <li><a class="dropdown-item" href="#">Mieux notées</a></li>
                    </ul>
                </div>
            </div>

            <div class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
                {% for i in 1..3 %}
                    <div class="col-md-4">
                        {# Appel du composant Carte de recette #}
                        {% include 'components/_recipe_card.html.twig' with {
                            'title': 'Ma super recette ' ~ i
                        } %}
                    </div>
                {% endfor %}
            </div>
        </section>

        {# 5. CATALOGUE COMPLET #}
        <section id="recipeCatalog" class="container py-5 border-top">

            {# Titre + filtres sur la même ligne, comme la section 4 #}
            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                <div>
                    <h2 class="fw-bold mb-0">Catalogue de Recettes</h2>
                    <p class="text-muted mb-0">Trouvez l'inspiration parmi toutes nos recettes</p>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <div class="dropdown">
                        <button class="btn btn-white border shadow-sm dropdown-toggle"
                                type="button" id="filterDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            Tous les régimes
                        </button>
                        <ul class="dropdown-menu shadow" aria-labelledby="filterDropdown">
                            <li><a class="dropdown-item active" href="#" data-filter="all">Tous les régimes</a></li>
                            <li><a class="dropdown-item" href="#" data-filter="Vegan">Vegan</a></li>
                            <li><a class="dropdown-item" href="#" data-filter="Végétarien">Végétarien</a></li>
                            <li><a class="dropdown-item" href="#" data-filter="Carné">Carné</a></li>
                        </ul>
                    </div>

                    <div class="dropdown">
                        <button class="btn btn-white border shadow-sm dropdown-toggle"
                                type="button" id="sortDropdown" data-bs-toggle="dropdown" aria-expanded="false">
                            Plus récents
                        </button>
                        <ul class="dropdown-menu shadow" aria-labelledby="sortDropdown">
                            <li><a class="dropdown-item active" href="#" data-sort="recent">Plus récents</a></li>
                            <li><a class="dropdown-item" href="#" data-sort="popular">Plus populaires</a></li>
                        </ul>
                    </div>
                </div>
            </div>

            {# Grille identique à la section 4 #}
            <div id="recipeGrid" class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
                {% for i in 1..3 %}
                    <div class="col-md-4">
                        {% include 'components/_recipe_card.html.twig' with {
                            'title': 'Ma super recette ' ~ i
                        } %}
                    </div>
                {% endfor %}
            </div>

            <div id="noResultMsg" class="text-center py-5 d-none">
                <i class="bi bi-search display-4 text-muted mb-3 d-block"></i>
                <h5 class="text-muted">Aucune recette ne correspond à vos critères.</h5>
            </div>
        </section>
    </main>

    {# 6. FOOTER #}
    {% include '_partials/footer.html.twig' %}
{% endblock %}

{% block javascripts %}
    {# Scripts spécifiques à la page d'accueil #}
    <script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js"></script>
    <script src="{{ asset('script.js') }}"></script>
{% endblock %}