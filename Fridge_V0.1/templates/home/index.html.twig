{% extends 'base.html.twig' %}

{% block title %}Accueil - Fridge{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/css/splide.min.css">
{% endblock %}

{% block body %}
{% set activeRegime = activeRegime|default('all') %}
{% set activeSort   = activeSort|default('recent') %}
    <main>
        {# 2. COMPONENT HERO #}
        {% include 'components/_hero.html.twig' %}

        {# 3. CARROUSEL (Recettes du moment) #}
        <section id="newRecipes" class="container py-5">
            <div class="text-center mb-5">
                <h2 class="fw-bold">Les Recettes du moment</h2>
                <p class="text-muted">Les pépites de la communauté</p>
            </div>

            <div class="splide" id="recipe-carousel">
                <div class="splide__track">
                    <ul class="splide__list">
                        {% for objRecette in arrRecettesCarousel %}
                            <li class="splide__slide px-2">
                                {% include 'components/_recipe_card.html.twig' with {
                                    title:      objRecette.recetteLibelle,
                                    time:       objRecette.recetteTempsPrepa + objRecette.recetteTempsCuisson,
                                    id:         objRecette.id,
                                    photo:      objRecette.recettePhoto,
                                    is_liked:   arrLikedIds[objRecette.id] is defined,
                                    like_count: arrLikeCounts[objRecette.id]|default(0),
                                    is_favori:  arrFavoriIds[objRecette.id] is defined
                                } %}
                            </li>
                        {% endfor %}
                    </ul>
                </div>
            </div>
        </section>

        {# 4. CATALOGUE COMPLET #}
        <section id="recipeCatalog" class="container py-5 border-top">

            <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-4 gap-3">
                <div>
                    <h2 class="fw-bold mb-0">Catalogue de Recettes</h2>
                    <p class="text-muted mb-0">Trouvez l'inspiration parmi toutes nos recettes</p>
                </div>

                <div class="d-flex flex-wrap gap-2">
                    <div class="dropdown">
                        <button class="btn btn-white border shadow-sm dropdown-toggle"
                                type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            {% if activeRegime == 'all' %}Tous les régimes
                            {% else %}{{ activeRegime }}
                            {% endif %}
                        </button>
                        <ul class="dropdown-menu shadow">
                            <li>
                                <a class="dropdown-item {{ activeRegime == 'all' ? 'active' }}"
                                href="{{ path('app_recette_index', {sort: activeSort}) }}">
                                    Tous les régimes
                                </a>
                            </li>
                            {% for label in ['Vegan', 'Végétarien', 'Omnivore'] %}
                                <li>
                                    <a class="dropdown-item {{ activeRegime == label ? 'active' }}"
                                    href="{{ path('app_recette_index', {regime: label, sort: activeSort}) }}">
                                        {{ label }}
                                    </a>
                                </li>
                            {% endfor %}
                        </ul>
                    </div>

                    <div class="dropdown">
                        <button class="btn btn-white border shadow-sm dropdown-toggle"
                                type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            {{ activeSort == 'popular' ? 'Plus populaires' : 'Plus récents' }}
                        </button>
                        <ul class="dropdown-menu shadow">
                            <li>
                                <a class="dropdown-item {{ activeSort == 'recent' ? 'active' }}"
                                href="{{ path('app_recette_index', {sort: 'recent', regime: activeRegime}) }}">
                                    Plus récents
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item {{ activeSort == 'popular' ? 'active' }}"
                                href="{{ path('app_recette_index', {sort: 'popular', regime: activeRegime}) }}">
                                    Plus populaires
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </div>

            <div id="recipeGrid" class="row row-cols-1 row-cols-sm-2 row-cols-lg-4 g-4">
                {% for objRecette in arrRecettes %}
                    <div class="col-md-4">
                        {% include 'components/_recipe_card.html.twig' with {
                            title:      objRecette.recetteLibelle,
                            time:       objRecette.recetteTempsPrepa + objRecette.recetteTempsCuisson,
                            id:         objRecette.id,
                            photo:      objRecette.recettePhoto,
                            is_liked:   arrLikedIds[objRecette.id] is defined,
                            like_count: arrLikeCounts[objRecette.id]|default(0),
                            is_favori:  arrFavoriIds[objRecette.id] is defined
                        } %}
                    </div>
                {% endfor %}
            </div>

            <div id="noResultMsg" class="text-center py-5 d-none">
                <i class="bi bi-search display-4 text-muted mb-3 d-block"></i>
                <h5 class="text-muted">Aucune recette ne correspond à vos critères.</h5>
            </div>

            <div class="d-flex justify-content-center mt-4">
                {{ knp_pagination_render(arrRecettes) }}
            </div>

        </section>
    </main>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/@splidejs/splide@4.1.4/dist/js/splide.min.js"></script>
    <script>
        function initSplide() {
            const el = document.getElementById('recipe-carousel');
            if (!el || el.classList.contains('is-initialized')) return;

            new Splide('#recipe-carousel', {
                type: 'loop',
                perPage: 3,
                perMove: 1,
                gap: '1.5rem',
                breakpoints: {
                    992: { perPage: 2 },
                    576: { perPage: 1 },
                },
            }).mount();
        }

        document.addEventListener('DOMContentLoaded', initSplide);
        document.addEventListener('turbo:load', initSplide);
        document.addEventListener('turbo:render', initSplide);
    </script>
{% endblock %}