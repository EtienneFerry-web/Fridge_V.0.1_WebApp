<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fridge - Cuisinez intelligemment</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="../assets/script/styles.css">
</head>
<body class="d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold" href="{{ path('home') }}">FRIDGE</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item"><a class="nav-link" href="{{ path('home') }}">Accueil</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('recipe_search') }}">Recettes</a></li>

                {# On vérifie si l'utilisateur est connecté #}
                {% if app.user %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('planning') }}">Planning</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('stock') }}">Stock</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('courses') }}">Courses</a></li>
                {% endif %}

                <li class="nav-item ms-lg-3">
                    {% if app.user %}
                        {# Lien si connecté #}
                        <a class="btn btn-outline-light btn-sm" href="{{ path('user_profile') }}">
                            <i class="bi bi-person-circle me-1"></i> Mon Compte
                        </a>
                    {% else %}
                        {# Lien si déconnecté #}
                        <a class="btn btn-primary btn-sm" href="{{ path('login') }}">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Connexion
                        </a>
                    {% endif %}
                </li>
            </ul>
        </div>
    </div>
</nav>