<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Fridge - Cuisinez intelligemment</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="{{ asset('styles/styles.css') }}">
    <link rel="icon" type="image/png" href="{{ asset('favicon/fridge_favicon.png') }}">
</head>
<body class="d-flex flex-column min-vh-100">

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">
    <div class="container">
        <a class="navbar-brand fw-bold" href="{{ path('app_home') }}">FRIDGE</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarMain">
            <ul class="navbar-nav ms-auto align-items-center">
                <li class="nav-item"><a class="nav-link" href="{{ path('app_home') }}">Accueil</a></li>
                <li class="nav-item"><a class="nav-link" href="{{ path('app_search') }}">Recettes</a></li>

                {# On vérifie si l'utilisateur est connecté #}
                {% if app.user %}
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_planning') }}">Planning</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_stock') }}">Stock</a></li>
                    <li class="nav-item"><a class="nav-link" href="{{ path('app_courses') }}">Courses</a></li>
                {% endif %}

                <li class="nav-item ms-lg-3">
                    {% if app.user %}
                        <a class="btn btn-outline-light btn-sm me-2" href="{{ path('app_user_profil') }}">
                            <i class="bi bi-person-circle me-1"></i> Mon Compte
                        </a>
                        <a class="btn btn-primary btn-sm" href="{{ path('app_logout') }}">
                            <i class="bi bi-box-arrow-right me-1"></i> Déconnexion
                        </a>
                    {% else %}
                        <a class="btn btn-primary btn-sm" href="{{ path('app_login') }}">
                            <i class="bi bi-box-arrow-in-right me-1"></i> Connexion
                        </a>
                    {% endif %}
                </li>
            </ul>
        </div>
    </div>
</nav>