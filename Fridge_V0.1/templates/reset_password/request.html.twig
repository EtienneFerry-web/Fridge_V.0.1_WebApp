{# templates/reset_password/request.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Mot de passe oublié - Fridge{% endblock %}

{% block body %}
    <main class="container py-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-5">

                <section class="card shadow-sm border-0">
                    <div class="card-body p-4 p-md-5">

                        <div class="text-center mb-3">
                            <i class="bi bi-shield-lock" style="font-size: 2.5rem;"></i>
                        </div>
                        <h1 class="text-center h2 mb-3">Mot de passe oublié ?</h1>
                        <p class="text-center text-muted mb-4 small">
                            Entrez votre e-mail pour recevoir un lien de réinitialisation.
                        </p>

                        {{ form_start(requestForm, {'attr': {'class': 'needs-validation', 'novalidate': 'novalidate'}}) }}

                            <div class="mb-3">
                                <label for="{{ requestForm.strEmail.vars.id }}" class="form-label">
                                    Adresse e-mail <span class="required-mark" aria-hidden="true">*</span>
                                </label>
                                <div class="input-group">
                                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                                    {{ form_widget(requestForm.strEmail, {
                                        'attr': {
                                            'class': 'form-control',
                                            'placeholder': 'marie@exemple.com',
                                            'autocomplete': 'email'
                                        }
                                    }) }}
                                </div>
                                {% if form_errors(requestForm.strEmail) %}
                                    <div class="text-danger small mt-1">
                                        {{ form_errors(requestForm.strEmail) }}
                                    </div>
                                {% endif %}
                            </div>

                            <div class="d-grid gap-2 mt-4">
                                <button type="submit" class="btn btn-primary btn-lg">
                                    Envoyer le lien <i class="bi bi-send ms-1"></i>
                                </button>
                            </div>

                            <p class="text-center mt-4 small text-muted">
                                Je m'en souviens ! <a href="{{ path('app_login') }}" class="text-decoration-none fw-bold">Retour à la connexion</a>
                            </p>

                        {{ form_end(requestForm) }}
                    </div>
                </section>

            </div>
        </div>
    </main>

{% endblock %}