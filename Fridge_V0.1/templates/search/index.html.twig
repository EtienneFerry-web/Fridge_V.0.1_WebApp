{% extends 'base.html.twig' %}

{% block title %}Recherche de Recettes - Fridge{% endblock %}

{% block body %}
    {# 1. HEADER #}
    {% include '_partials/header.html.twig' %}

    {# 2. FIL D'ARIANE #}
    <nav aria-label="Fil d'ariane">
        <div class="container pt-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_home') }}"><i class="bi bi-house me-1"></i>Accueil</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Recettes</li>
            </ol>
        </div>
    </nav>

    {# 3. HERO RECHERCHE #}
    <section class="search-hero">
        <div class="container">
            <h1 class="fw-bold mb-3">Trouvez la recette parfaite</h1>
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6">
                    <form class="d-flex shadow-lg rounded-pill" role="search" method="GET" action="{{ path('app_search') }}">
                        <input class="form-control main-search-input"
                               type="search"
                               name="q"
                               value="{{ app.request.query.get('q') }}"
                               placeholder="Que voulez-vous cuisiner ?"
                               aria-label="Rechercher">
                        <button class="btn main-search-btn text-white" type="submit">Rechercher</button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <main class="container mb-5 mt-4">
        <div class="row">

            {# 4. SIDEBAR FILTRES #}
            <aside class="col-lg-3 mb-4">
                <div class="card shadow-sm border-0 position-sticky" style="top: 85px; z-index: 10;">
                    <div class="card-body">
                        <h5 class="fw-bold mb-4 border-bottom pb-2 d-flex align-items-center">
                            <i class="bi bi-sliders me-2 text-success"></i> Filtres
                        </h5>

                        <form id="filterForm">

                            <div class="mb-4">
                                <h6 class="fw-bold mb-2">Régime alimentaire</h6>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="filterVegetarian">
                                    <label class="form-check-label" for="filterVegetarian">Végétarien</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="filterVegan">
                                    <label class="form-check-label" for="filterVegan">Vegan</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="filterGlutenFree">
                                    <label class="form-check-label" for="filterGlutenFree">Sans gluten</label>
                                </div>
                            </div>

                            <div class="mb-4">
                                <h6 class="fw-bold mb-2">Difficulté</h6>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="diffEasy">
                                    <label class="form-check-label" for="diffEasy">Facile</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="diffMedium">
                                    <label class="form-check-label" for="diffMedium">Moyenne</label>
                                </div>
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" id="diffHard">
                                    <label class="form-check-label" for="diffHard">Difficile</label>
                                </div>
                            </div>

                            <div class="mb-4">
                                <h6 class="fw-bold mb-2">Origine</h6>
                                <select class="form-select form-select-sm shadow-none" id="filterOrigin">
                                    <option value="">Toutes les origines</option>
                                    <option value="fr">Française</option>
                                    <option value="it">Italienne</option>
                                    <option value="asia">Asiatique</option>
                                    <option value="mex">Mexicaine</option>
                                    <option value="orient">Orientale</option>
                                </select>
                            </div>

                            <div class="mb-4">
                                <h6 class="fw-bold mb-2">Temps de préparation max.</h6>
                                <input type="range" class="form-range" min="5" max="120" step="5" id="timeRange"
                                       oninput="document.getElementById('timeValue').innerText = this.value + ' min'">
                                <div class="text-end small text-muted fw-bold" id="timeValue">60 min</div>
                            </div>

                            <button type="reset" class="btn btn-outline-secondary btn-sm w-100 mt-2">
                                Réinitialiser les filtres
                            </button>

                        </form>
                    </div>
                </div>
            </aside>

            {# 5. GRILLE DE RÉSULTATS #}
            <div class="col-lg-9">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="text-muted">
                        <strong class="text-dark" id="resultsCount">{{ recipes|length }}</strong> recettes trouvées
                    </span>
                    <div class="d-flex align-items-center">
                        <label for="sortResults" class="me-2 small text-muted text-nowrap">Trier par :</label>
                        <select class="form-select form-select-sm border-0 shadow-sm w-auto bg-light" id="sortResults">
                            <option value="pertinence">Pertinence</option>
                            <option value="recent">Plus récents</option>
                            <option value="time">Temps le plus court</option>
                        </select>
                    </div>
                </div>

                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 mb-5" id="searchResultsGrid">
                    {% for recipe in recipes %}
                        <div class="col">
                            {% include 'components/_recipe_card.html.twig' with {
                                title: recipe.title,
                                time: recipe.time,
                                image: recipe.image
                            } %}
                        </div>
                    {% else %}
                        <p class="text-muted">Aucune recette trouvée.</p>
                    {% endfor %}
                </div>

            </div>
        </div>
    </main>

    {# 6. FOOTER #}
    {% include '_partials/footer.html.twig' %}
{% endblock %}