{% extends 'base.html.twig' %}

{% block title %}Recherche de Recettes - Fridge{% endblock %}

{% block body %}
    {% include '_partials/header.html.twig' %}

    <nav aria-label="Fil d'ariane">
        <div class="container pt-3">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_home') }}"><i class="bi bi-house me-1"></i>Accueil</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Recettes</li>
            </ol>
        </div>
    </nav>

    {# HERO RECHERCHE #}
    <section class="search-hero">
        <div class="container">
            <h1 class="fw-bold mb-3">Trouvez la recette parfaite</h1>
            <div class="row justify-content-center">
                <div class="col-md-8 col-lg-6">
                    <form class="d-flex shadow-lg rounded-pill" role="search"
                          method="GET" action="{{ path('app_search') }}">
                        <input class="form-control main-search-input"
                               type="search"
                               name="q"
                               value="{{ query }}"
                               placeholder="Que voulez-vous cuisiner ?"
                               aria-label="Rechercher">
                        <button class="btn main-search-btn text-white" type="submit">
                            Rechercher
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <main class="container mb-5 mt-4">
        <div class="row">

            {# SIDEBAR FILTRES — tout dans un seul <form> lié aux résultats #}
            <aside class="col-lg-3 mb-4">
                <div class="card shadow-sm border-0 position-sticky" style="top: 85px; z-index: 10;">
                    <div class="card-body">
                        <h5 class="fw-bold mb-4 border-bottom pb-2 d-flex align-items-center">
                            <i class="bi bi-sliders me-2 text-success"></i> Filtres
                        </h5>

                        {# Un seul form englobe sidebar + tri — soumis via JS au changement #}
                        <form id="filterForm" method="GET" action="{{ path('app_search') }}">

                            {# On conserve le mot-clé de recherche #}
                            <input type="hidden" name="q" value="{{ query }}">

                            {# --- Régime alimentaire (dynamique) --- #}
                            <div class="mb-4">
                                <h6 class="fw-bold mb-2">Régime alimentaire</h6>
                                {% for reg in regimes %}
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               name="regimes[]"
                                               value="{{ reg.id }}"
                                               id="regime_{{ reg.id }}"
                                               {% if reg.id ~ '' in regimes %}checked{% endif %}>
                                        <label class="form-check-label" for="regime_{{ reg.id }}">
                                            {{ reg.regimeLibelle }}
                                        </label>
                                    </div>
                                {% endfor %}
                            </div>

                            {# --- Difficulté --- #}
                            <div class="mb-4">
                                <h6 class="fw-bold mb-2">Difficulté</h6>
                                {% for level in ['Facile', 'Moyen', 'Difficile'] %}
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox"
                                               name="difficulte[]"
                                               value="{{ level }}"
                                               id="diff_{{ level }}"
                                               {% if level in difficulte %}checked{% endif %}>
                                        <label class="form-check-label" for="diff_{{ level }}">
                                            {{ level }}
                                        </label>
                                    </div>
                                {% endfor %}
                            </div>

                            {# --- Origine --- #}
                            <div class="mb-4">
                                <h6 class="fw-bold mb-2">Origine</h6>
                                <select class="form-select form-select-sm shadow-none" name="origine">
                                    <option value="">Toutes les origines</option>
                                    {% for val, label in {
                                        'fr': 'Française',
                                        'it': 'Italienne',
                                        'asia': 'Asiatique',
                                        'mex': 'Mexicaine',
                                        'orient': 'Orientale'
                                    } %}
                                        <option value="{{ val }}" {% if origine == val %}selected{% endif %}>
                                            {{ label }}
                                        </option>
                                    {% endfor %}
                                </select>
                            </div>

                            {# --- Temps max --- #}
                            <div class="mb-4">
                                <h6 class="fw-bold mb-2">Temps de préparation max.</h6>
                                <input type="range" class="form-range"
                                       min="5" max="120" step="5"
                                       name="temps_preparation_max"
                                       id="timeRange"
                                       value="{{ temps_preparation_max }}"
                                       oninput="document.getElementById('timeValue').innerText = this.value + ' min'">
                                <div class="text-end small text-muted fw-bold" id="timeValue">
                                    {{ temps_preparation_max }} min
                                </div>
                            </div>

                            <button type="submit" class="btn btn-dark btn-sm w-100">
                                <i class="bi bi-funnel me-1"></i>Appliquer
                            </button>
                            <a href="{{ path('app_search', {q: query}) }}"
                               class="btn btn-outline-secondary btn-sm w-100 mt-2">
                                Réinitialiser les filtres
                            </a>

                        </form>
                    </div>
                </div>
            </aside>

            {# GRILLE DE RÉSULTATS #}
            <div class="col-lg-9">

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <span class="text-muted">
                        <strong class="text-dark">{{ recipes|length }}</strong> recette(s) trouvée(s)
                    </span>
                    <div class="d-flex align-items-center">
                        <label for="sortResults" class="me-2 small text-muted text-nowrap">
                            Trier par :
                        </label>
                        {# Le tri recharge la page via JS en ajoutant ?sort= à l'URL #}
                        <select class="form-select form-select-sm border-0 shadow-sm w-auto bg-light"
                                id="sortResults"
                                onchange="updateSort(this.value)">
                            <option value="pertinence" {% if sort_by == 'pertinence' %}selected{% endif %}>
                                Pertinence
                            </option>
                            <option value="recent"     {% if sort_by == 'recent'     %}selected{% endif %}>
                                Plus récents
                            </option>
                            <option value="time"       {% if sort_by == 'time'       %}selected{% endif %}>
                                Temps le plus court
                            </option>
                        </select>
                    </div>
                </div>

                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4 mb-5">
                    {% for recipe in recipes %}
                        <div class="col">
                            {% include 'components/_recipe_card.html.twig' with {
                                title: recipe.recetteLibelle,
                                time:  recipe.recetteTempsPrepa + recipe.recetteTempsCuisson,
                                photo: recipe.recettePhoto ?? null,
                                id:    recipe.id,
                                is_liked:   arrLikedIds[recipe.id] is defined,
                                like_count: arrLikeCounts[recipe.id]|default(0),
                                is_favori:  arrFavoriIds[recipe.id] is defined
                            } %}
                        </div>
                    {% else %}
                        <div class="col-12">
                            <p class="text-muted">Aucune recette ne correspond à ta recherche.</p>
                        </div>
                    {% endfor %}
                </div>

            </div>
        </div>
    </main>

    {% include '_partials/footer.html.twig' %}

    <script>
    // Synchronise le select "Trier par" avec le form sidebar
    function updateSort(strSortValue) {
        const objForm = document.getElementById('filterForm');
        let objSortInput = objForm.querySelector('input[name="sort_by"]');
        if (!objSortInput) {
            objSortInput = document.createElement('input');
            objSortInput.type = 'hidden';
            objSortInput.name = 'sort_by';
            objForm.appendChild(objSortInput);
        }
        objSortInput.value = strSortValue;
        objForm.submit();
    }
    </script>
{% endblock %}