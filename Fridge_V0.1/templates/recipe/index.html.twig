{# templates/recipe/show.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Recette : {{ recipe.title ?? 'Poulet au Curry' }} - Fridge{% endblock %}

{% block body %}
    {# 1. HEADER #}
    {% include '_partials/header.html.twig' %}

    <main class="flex-shrink-0">

        {# 2. FIL D'ARIANE #}
        <nav aria-label="Fil d'ariane">
            <div class="container pt-3">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_home') }}"><i class="bi bi-house me-1"></i>Accueil</a>
                    </li>
                    <li class="breadcrumb-item">
                        <a href="{{ path('app_recipe') }}">Recettes</a>
                    </li>
                    <li class="breadcrumb-item active" aria-current="page">
                        {{ recipe.title ?? 'Poulet au Curry Express' }}
                    </li>
                </ol>
            </div>
        </nav>

        {# 3. DÉTAIL DE LA RECETTE #}
        <section class="container py-5" id="recipe">
            <div class="row mx-auto shadow-sm bg-white rounded p-4">

                {# Colonne image + favoris #}
                <div class="col-12 col-md-4 text-center">
                    <img
                        src="{{ recipe.image ?? 'https://images.unsplash.com/photo-1588166524941-3bf61a9c41db?auto=format&fit=crop&w=600' }}"
                        alt="{{ recipe.title ?? 'Recette' }}"
                        class="img-fluid rounded shadow-sm w-100"
                    >
                    <div class="py-4">
                        <button class="btn btn-outline-danger w-100 mb-3 py-2 fw-bold">
                            <i class="bi bi-bookmark-heart me-2"></i> Ajouter aux favoris
                        </button>
                    </div>
                </div>

                {# Colonne infos #}
                <div class="col-12 col-md-8 py-3 py-md-2 text-center text-md-start">
                    <h1 class="mb-3">{{ recipe.title ?? 'Poulet au Curry Express' }}</h1>

                    <div class="mb-4 d-flex flex-wrap justify-content-center justify-content-md-start gap-3">
                        <span class="badge bg-light text-dark border py-2 px-3">
                            <strong><i class="bi bi-clock me-1"></i> Préparation :</strong>
                            {{ recipe.time ?? '25' }} min
                        </span>
                        <span class="badge bg-light text-dark border py-2 px-3">
                            <strong><i class="bi bi-people me-1"></i> Portions :</strong>
                            {{ recipe.servings ?? '4' }} pers.
                        </span>
                    </div>

                    <h4 class="mb-2 border-bottom pb-2 text-success">Description</h4>
                    <p class="px-2 px-md-0 mb-4 text-muted">
                        {{ recipe.description ?? 'Une recette onctueuse et parfumée, idéale pour les soirs de semaine pressés.' }}
                    </p>
                </div>

            </div>
        </section>

    </main>

    {# 4. FOOTER #}
    {% include '_partials/footer.html.twig' %}
{% endblock %}