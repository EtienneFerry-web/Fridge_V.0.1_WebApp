{% extends 'base.html.twig' %}

{% block title %}Modifier le Profil - Fridge{% endblock %}

{% block body %}

{% include '_partials/header.html.twig' %}

<nav class="breadcrumb-nav" aria-label="Fil d'ariane">
    <div class="container">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('app_home') }}"><i class="bi bi-house me-1"></i>Accueil</a>
            </li>
            <li class="breadcrumb-item">
                <a href="{{ path('app_user_profil') }}">Mon Profil</a>
            </li>
            <li class="breadcrumb-item active" aria-current="page">Modifier le profil</li>
        </ol>
    </div>
</nav>

<main class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6 col-md-8">

            <div class="card shadow-sm border-0 rounded-3">
                <div class="card-body p-4 p-md-5">
                    <h2 class="h4 mb-4 fw-bold text-center">Modifier mon profil</h2>

                    {{ form_start(form, {action: path('app_edit_user_profil'), method: 'POST', attr: {novalidate: 'novalidate'}}) }}

                        <div class="d-flex flex-column align-items-center mb-5">
                            <img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=250"
                                alt="Profil" class="rounded-circle avatar-img mb-3">
                            <label for="avatarUpload"
                                class="btn-edit-avatar rounded-circle d-flex align-items-center justify-content-center shadow-sm"
                                style="width:44px;height:44px;cursor:pointer;">
                                <i class="bi bi-camera-fill"></i>
                            </label>
                            <input type="file" id="avatarUpload" class="d-none-file" accept="image/*">
                            <div class="form-text mt-2 small text-center">JPG ou PNG. Max 2 Mo.</div>
                        </div>

                        <h5 class="mb-3 text-secondary border-bottom pb-2">Informations personnelles</h5>

                        <div class="row g-3 mb-3">
                            <div class="col-md-6">
                                <label class="form-label fw-medium"><i class="bi bi-person"></i> Prénom</label>
                                {{ form_widget(form.strFirstname, {attr: {class: 'form-control'}}) }}
                            </div>
                            <div class="col-md-6">
                                <label class="form-label fw-medium"><i class="bi bi-person"></i> Nom</label>
                                {{ form_widget(form.strName, {attr: {class: 'form-control'}}) }}
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-medium"><i class="bi bi-at"></i> Pseudo</label>
                            {{ form_widget(form.strUsername, {attr: {class: 'form-control'}}) }}
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-medium"><i class="bi bi-envelope"></i> Adresse Email</label>
                            {{ form_widget(form.strEmail, {attr: {class: 'form-control'}}) }}
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-medium"><i class="bi bi-tag"></i> Régimes alimentaires</label>
                            <div class="d-flex flex-wrap gap-2 mt-1">
                                {{ form_widget(form.regimes) }}
                            </div>
                        </div>

                        <hr class="my-4">

                        <h5 class="mb-3 text-secondary border-bottom pb-2">Sécurité</h5>

                        <div class="mb-3">
                            <label class="form-label fw-medium"><i class="bi bi-key"></i> Nouveau mot de passe</label>
                            {{ form_widget(form.newPassword.first, {attr: {class: 'form-control'}}) }}
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-medium"><i class="bi bi-key"></i> Confirmer le mot de passe</label>
                            {{ form_widget(form.newPassword.second, {attr: {class: 'form-control'}}) }}
                        </div>

                        <div class="d-grid gap-2 mt-5">
                            <button type="submit" class="btn btn-primary py-2">
                                <i class="bi bi-save me-1"></i> Enregistrer les modifications
                            </button>
                            <a href="{{ path('app_user_profil') }}" class="btn btn-outline-secondary">Annuler</a>
                        </div>

                        <hr class="my-4">

                        <div class="text-center">
                            <button type="button"
                                    class="btn btn-outline-danger btn-sm"
                                    data-bs-toggle="modal"
                                    data-bs-target="#modalDeleteAccount">
                                <i class="bi bi-trash me-1"></i> Supprimer mon compte
                            </button>
                        </div>

                    {{ form_end(form) }}
                </div>
            </div>

        </div>
    </div>
</main>
{# Modale confirmation suppression #}
<div class="modal fade" id="modalDeleteAccount" tabindex="-1" aria-labelledby="modalDeleteLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header border-0">
                <h5 class="modal-title text-danger fw-bold" id="modalDeleteLabel">
                    <i class="bi bi-exclamation-triangle me-2"></i>Supprimer mon compte
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-4">
                <p class="mb-1">Es-tu sûr de vouloir supprimer ton compte ?</p>
                <p class="text-muted small">Cette action est irréversible. Toutes tes données seront désactivées.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center gap-2">

                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    Annuler
                </button>

                <form action="{{ path('app_user_profil_delete') }}" method="POST">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i> Oui, supprimer
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>
{% include '_partials/footer.html.twig' %}

{% endblock %}