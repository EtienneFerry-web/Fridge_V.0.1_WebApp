{% extends 'base.html.twig' %}

{% block title %}Mon Profil - Fridge{% endblock %}

{% block body %}
    {# 1. HEADER #}
    {% include '_partials/header.html.twig' %}

    <main class="container py-4">

        {# 2. FIL D'ARIANE #}
        <nav aria-label="Fil d'ariane">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a href="{{ path('app_home') }}"><i class="bi bi-house me-1"></i>Accueil</a>
                </li>
                <li class="breadcrumb-item active" aria-current="page">Mon Profil</li>
            </ol>
        </nav>

        {# 3. CARTE UTILISATEUR #}
        <section id="user" class="bg-white shadow-sm rounded-3 p-4 mb-4">
            <div class="row align-items-center text-center text-md-start">

                <div class="col-8 col-md-3 col-lg-2 mx-auto mb-3 mb-md-0">
                    <img src="https://images.unsplash.com/photo-1535713875002-d1d0cf377fde?auto=format&fit=crop&w=150"
                         alt="Photo de profil"
                         class="img-fluid rounded-circle border border-4 border-light shadow-sm">
                </div>

                <div class="col-12 col-md-9 col-lg-10">
                    <h1 class="h2 fw-bold mb-1">
                        {{ app.user.strFirstname }} {{ app.user.strName }}
                    </h1>
                    <p class="text-muted mb-1 small">@{{ app.user.strUsername }}</p>
                    <p class="text-muted mb-3 small fst-italic">"Cuisiner est un art, mais manger est un plaisir."</p>

                    <div class="mt-3 d-flex flex-wrap gap-2 justify-content-center justify-content-md-start">
                        <a href="{{ path('app_edit_user_profil') }}" class="btn btn-sm btn-outline-dark">
                            <i class="bi bi-gear me-1"></i> Paramètres
                        </a>
                    </div>
                </div>

            </div>
        </section>

        {# 4. MES LIKES #}
        <section class="bg-white shadow-sm rounded-3 p-4 mb-4">
            <h2 class="h5 fw-bold mb-3 d-flex align-items-center gap-2">
                <i class="bi bi-heart-fill text-danger"></i> Mes Likes
            </h2>

            
            <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
                {% for objLike in arrLikes %}
                    <div class="col">
                        {% include 'components/_recipe_card.html.twig' with {
                            title: objLike.likeRecette.recetteLibelle,
                            time:  objLike.likeRecette.recetteTempsPrepa + objLike.likeRecette.recetteTempsCuisson,
                            photo: objLike.likeRecette.recettePhoto
                        } %}
                    </div>
                {% else %}
                    <p class="text-muted small">Vous n'avez pas encore liké de recettes.</p>
                {% endfor %}
            </div>
        </section>

        {# 5. MES FAVORIS #}
        <section class="bg-white shadow-sm rounded-3 p-4 mb-4">
            <h2 class="h5 fw-bold mb-3 d-flex align-items-center gap-2">
                <i class="bi bi-bookmark-star-fill text-warning"></i> Mes Favoris
            </h2>

            
            <ul class="list-group list-group-flush">
                {% for objFavori in arrFavoris %}
                    <li class="list-group-item px-0 d-flex align-items-center gap-3 bg-transparent">
                        <div class="flex-grow-1 min-w-0">
                            <p class="mb-0 fw-medium small text-truncate">
                                {{ objFavori.favoriRecette.recetteLibelle }}
                            </p>
                            <span class="text-muted small">
                                {{ objFavori.favoriRecette.recetteDifficulte|capitalize }}
                                · {{ objFavori.favoriRecette.recetteTempsPrepa + objFavori.favoriRecette.recetteTempsCuisson }} min
                            </span>
                        </div>
                        <a href="{{ path('app_recette_index') }}" class="btn btn-sm btn-outline-dark flex-shrink-0">Voir</a>
                    </li>
                {% else %}
                    <p class="text-muted small mt-2">Vous n'avez pas encore ajouté de favoris.</p>
                {% endfor %}
            </ul>
        </section>

    </main>

    {# 6. FOOTER #}
    {% include '_partials/footer.html.twig' %}
{% endblock %}